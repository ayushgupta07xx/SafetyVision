# ─── LLM Configuration ────────────────────────────────────────────
GOOGLE_AI_STUDIO_KEY=your_google_ai_studio_key_here
GROQ_API_KEY=your_groq_api_key_here          # A/B test judge + fallback

# ─── Vector Store ─────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ─── Model ────────────────────────────────────────────────────────
HF_MODEL_REPO=your-username/safetyvision-yolov8
HF_TOKEN=your_hf_token_here

# ─── AWS (only needed for Mode 2 deployment) ──────────────────────
AWS_REGION=ap-south-1
AWS_S3_MODEL_BUCKET=safetyvision-models
AWS_DYNAMODB_TABLE=safetyvision-violations
# AWS credentials via `aws configure`, NOT in .env

# ─── Experiment Tracking ──────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=safetyvision
MLFLOW_TRACKING_URI=file:./mlruns

# ─── App Config ───────────────────────────────────────────────────
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.50
MAX_VIDEO_DURATION_SECONDS=30
